# StockScope — environment variables
# LOCAL DEV: copy this file to ".env" and fill in keys, then run the backend.
# VERCEL: don't use this file — add these same names in the Vercel dashboard
#         (Project → Settings → Environment Variables). Never commit real keys.

# --- Data providers (all optional; without them it falls back to Yahoo) ---
# Finnhub (free 60 req/min) — quotes, news, SEC filings, search.
#   Get a key: https://finnhub.io/register
FINNHUB_KEY=

# Alpaca (free 200 req/min) — historical chart bars.
#   Get keys (Paper account is fine): https://alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# --- Security ---
# Only needed if your frontend is on a DIFFERENT domain than the API.
# In the single-Vercel setup they share a domain, so you can leave this blank.
ALLOWED_ORIGINS=

# Rate limiter (per IP). Defaults are fine.
RATE_MAX=120
RATE_WINDOW_MS=60000
